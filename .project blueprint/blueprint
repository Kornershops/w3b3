```sql
-- Users (minimal tracking)
CREATE TABLE users (
  id UUID PRIMARY KEY,
  wallet_address VARCHAR(255) UNIQUE NOT NULL,
  chain_id INTEGER, -- primary chain (1=ETH, 137=Polygon, etc.)
  created_at TIMESTAMP DEFAULT NOW()
);

-- Staking Pools (indexed from blockchain)
CREATE TABLE staking_pools (
  id UUID PRIMARY KEY,
  name VARCHAR(255),
  chain_id INTEGER NOT NULL, -- 1(ETH), 137(Polygon), 501(Solana), 8453(Base)
  contract_address VARCHAR(255) NOT NULL,
  token_symbol VARCHAR(20),
  token_decimals INTEGER,
  apy_percentage DECIMAL(5, 2),
  tvl_amount DECIMAL(30, 8), -- Total Value Locked
  minimum_stake DECIMAL(20, 8),
  is_active BOOLEAN DEFAULT TRUE,
  created_at TIMESTAMP DEFAULT NOW(),
  UNIQUE(chain_id, contract_address)
);

-- User Stakes (core table)
CREATE TABLE user_stakes (
  id UUID PRIMARY KEY,
  user_id UUID REFERENCES users(id),
  pool_id UUID REFERENCES staking_pools(id),
  amount_staked DECIMAL(20, 8),
  rewards_claimed DECIMAL(20, 8) DEFAULT 0,
  transaction_hash VARCHAR(255),
  staked_at TIMESTAMP DEFAULT NOW(),
  unstaked_at TIMESTAMP,
  is_active BOOLEAN DEFAULT TRUE
);

-- Rewards Tracking
CREATE TABLE rewards (
  id UUID PRIMARY KEY,
  stake_id UUID REFERENCES user_stakes(id),
  amount DECIMAL(20, 8),
  claimed_at TIMESTAMP,
  transaction_hash VARCHAR(255)
);

-- Create indexes for queries
CREATE INDEX idx_user_stakes_user_id ON user_stakes(user_id);
CREATE INDEX idx_user_stakes_pool_id ON user_stakes(pool_id);
CREATE INDEX idx_staking_pools_chain ON staking_pools(chain_id);
```

