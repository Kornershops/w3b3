// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  walletAddress String   @unique
  chainId       Int?
  role          String   @default("USER")
  referralCode  String   @unique @default(cuid())
  referredById  String?
  points        Int      @default(0)
  kycStatus     String   @default("UNVERIFIED")
  isInstitutional Boolean @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  stakes          UserStake[]
  rewards         Reward[]
  creditPositions CreditPosition[]
  institutionalVaults InstitutionalVault[]
  proposals       CustodyProposal[]

  @@map("users")
}

model StakingPool {
  id              String   @id @default(cuid())
  name            String
  chainId         Int
  contractAddress String
  tokenSymbol     String
  tokenDecimals   Int
  apyPercentage   Decimal  @db.Decimal(5, 2)
  tvlAmount       Decimal  @db.Decimal(30, 8)
  minimumStake    Decimal  @db.Decimal(20, 8)
  isActive        Boolean  @default(true)
  isInstitutionalOnly Boolean @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  userStakes UserStake[]
  analytics  PoolAnalytics?

  @@unique([chainId, contractAddress])
  @@index([chainId])
  @@map("staking_pools")
}

model PoolAnalytics {
  id              String   @id @default(cuid())
  poolId          String   @unique
  historicalTvl   Json?    // Array of { tvl: number, timestamp: number }
  historicalPrice Json?    // Array of { price: number, timestamp: number }
  confidenceScore Decimal  @default(0.95) @db.Decimal(5, 4)
  trend           String   @default("STABLE") // BULLISH, BEARISH, STABLE
  updatedAt       DateTime @updatedAt
  
  pool            StakingPool @relation(fields: [poolId], references: [id], onDelete: Cascade)
  
  @@map("pool_analytics")
}

model UserStake {
  id              String   @id @default(cuid())
  userId          String
  poolId          String
  amountStaked    Decimal  @db.Decimal(20, 8)
  rewardsClaimed  Decimal  @default(0) @db.Decimal(20, 8)
  transactionHash String?
  stakedAt        DateTime @default(now())
  unstakedAt      DateTime?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  pool    StakingPool  @relation(fields: [poolId], references: [id], onDelete: Cascade)
  rewards Reward[]

  @@index([userId])
  @@index([poolId])
  @@map("user_stakes")
}

model Reward {
  id              String   @id @default(cuid())
  stakeId         String
  userId          String
  amount          Decimal  @db.Decimal(20, 8)
  claimedAt       DateTime?
  transactionHash String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  stake UserStake @relation(fields: [stakeId], references: [id], onDelete: Cascade)
  user  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([stakeId])
  @@index([userId])
  @@map("rewards")
}

model CreditPosition {
  id               String   @id @default(cuid())
  userId           String
  collateralAsset  String
  borrowedAsset    String
  collateralAmount Decimal  @db.Decimal(30, 8)
  borrowedAmount   Decimal  @db.Decimal(30, 8)
  healthFactor     Decimal? @db.Decimal(10, 4)
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([collateralAsset])
  @@map("credit_positions")
}

model InstitutionalVault {
  id              String   @id @default(cuid())
  ownerId         String
  name            String
  address         String   @unique
  threshold       Int      @default(1)
  payoutAddress   String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  owner           User              @relation(fields: [ownerId], references: [id])
  signers         VaultSigner[]
  proposals       CustodyProposal[]

  @@map("institutional_vaults")
}

model VaultSigner {
  id              String   @id @default(cuid())
  vaultId         String
  address         String
  name            String?
  createdAt       DateTime @default(now())

  vault           InstitutionalVault @relation(fields: [vaultId], references: [id], onDelete: Cascade)

  @@unique([vaultId, address])
  @@map("vault_signers")
}

model CustodyProposal {
  id                    String   @id @default(cuid())
  vaultId               String
  userId                String
  transactionData       String   @db.Text
  metadata              String?  @db.Text
  status                String   @default("PENDING") // PENDING, EXECUTED, REJECTED
  requiredConfirmations Int
  currentConfirmations  Int      @default(0)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  vault                 InstitutionalVault @relation(fields: [vaultId], references: [id], onDelete: Cascade)
  initiator             User               @relation(fields: [userId], references: [id])
  approvals             ProposalApproval[]

  @@map("custody_proposals")
}

model ProposalApproval {
  id            String   @id @default(cuid())
  proposalId    String
  signerAddress String
  createdAt     DateTime @default(now())

  proposal      CustodyProposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)

  @@unique([proposalId, signerAddress])
  @@map("proposal_approvals")
}

model TreasuryAsset {
  id              String   @id @default(cuid())
  symbol          String
  address         String   @unique
  decimals        Int
  oracleId        String?  // CoinGecko or Chainlink identifier
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("treasury_assets")
}
