# W3B3 Environment Variables Template
# Copy this file to .env and fill in your values

# ============================================
# FRONTEND ENVIRONMENT VARIABLES
# ============================================

# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_ENVIRONMENT=development

# Web3 Configuration
NEXT_PUBLIC_WC_PROJECT_ID=your_walletconnect_project_id
NEXT_PUBLIC_ALCHEMY_API_KEY=your_alchemy_api_key

# ============================================
# BACKEND ENVIRONMENT VARIABLES
# ============================================

# Server Configuration
NODE_ENV=development
PORT=3001
LOG_LEVEL=debug

# Database Configuration
DATABASE_URL=postgresql://postgres:password@localhost:5432/w3b3
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# Redis Configuration
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Web3 Configuration
ALCHEMY_API_KEY=your_alchemy_api_key
ALCHEMY_WEBHOOK_SIGNING_KEY=your_webhook_signing_key

# CORS Configuration
CORS_ORIGIN=http://localhost:3000
CORS_CREDENTIALS=true

# Email Configuration (Optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# ============================================
# SMART CONTRACTS ENVIRONMENT VARIABLES
# ============================================

# Private Key (DO NOT COMMIT)
PRIVATE_KEY=your_private_key_here

# Block Explorer API Keys
ETHERSCAN_API_KEY=your_etherscan_api_key
POLYGONSCAN_API_KEY=your_polygonscan_api_key
BASESCAN_API_KEY=your_basescan_api_key
SOLSCAN_API_KEY=your_solscan_api_key

# RPC Endpoints
ETHEREUM_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/your_alchemy_key
POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/your_alchemy_key
BASE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/your_alchemy_key
SOLANA_RPC_URL=https://solana-mainnet.g.alchemy.com/v2/your_alchemy_key

# ============================================
# MONITORING & ANALYTICS
# ============================================

# Sentry Configuration
SENTRY_DSN=your_sentry_dsn
SENTRY_ENVIRONMENT=development

# LogRocket Configuration
LOGROCKET_ID=your_logrocket_id

# ============================================
# DEPLOYMENT CONFIGURATION
# ============================================

# Vercel (Frontend)
VERCEL_TOKEN=your_vercel_token
VERCEL_PROJECT_ID=your_vercel_project_id

# AWS Configuration (Backend)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key

# ============================================
# FEATURE FLAGS
# ============================================

ENABLE_MEMECOIN_POOLS=true
ENABLE_REFERRAL_SYSTEM=false
ENABLE_GOVERNANCE=false
MAINTENANCE_MODE=false
